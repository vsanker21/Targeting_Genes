# Copy to .env or set in your shell (do not commit real keys).
# LINCS CLUE — https://api.clue.io / https://clue.io/
# CLUE_API_KEY=your_user_key_here
# Or point to a file outside the repo:
# CLUE_API_TOKEN_FILE=C:\Users\you\.secrets\clue_key.txt
# After setting either variable, fetch JSON snapshots into data_root/lincs/:
#   python scripts/fetch_clue_api_subset.py
# Or run the full orchestrator (CLUE phase only when a key is present):
#   python scripts/download_all_required.py

# Windows: avoid UnicodeEncodeError in long Snakemake / Python runs (cp1252 console).
# PYTHONUTF8=1

# Optional Snakemake rule all extras — see docs/GBM_DETECTION_AND_OPEN_DATA.md
# GLIOMA_TARGET_INCLUDE_SUPPLEMENTARY_WIRING=1

# Module 7 human-facing outputs (pip install -r requirements-dev.txt: matplotlib + python-docx).
# Bundle: one flag pulls UHD figures + Word report (do not also set VIZ/DOCX below).
# GLIOMA_TARGET_INCLUDE_M7_DELIVERABLES=1
# Or separately:
# GLIOMA_TARGET_INCLUDE_M7_VIZ=1
# GLIOMA_TARGET_INCLUDE_M7_DOCX=1
# All optional rule-all flags (ClinVar, Scanpy, MOVICS, supplementary, M7): docs/OPTIONAL_SLICES.md

# Auto-patch WikiPathways GMT URL when running: scripts/sync_wikipathways_gmt_url.py --write-yaml
# GLIOMA_TARGET_WIKIPATHWAYS_SYNC_YAML=1

# DrugCentral → PostgreSQL via scripts/drugcentral_postgres_load_status.py (needs psql on PATH)
# GLIOMA_TARGET_DRUGCENTRAL_LOAD=1
# GLIOMA_TARGET_DRUGCENTRAL_DATABASE=drugcentral
